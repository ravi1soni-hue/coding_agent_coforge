<idea-plugin>
    <id>com.coforge.codingagent</id>
    <name>Coforge AI Coding Agent</name>
    <vendor email="support@coforge.com" url="https://www.coforge.com">Coforge</vendor>

    <description><![CDATA[
        Elite AI Coding Agent for Android architects and lead developers.<br/>
        <b>Kimi K2</b> reasons · <b>Gemini</b> reviews · <b>GPT-5</b> streams the implementation.<br/>
        Inline ghost-text completions, context-menu quick actions, diff preview before applying changes.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">

        <!-- Tool window (chat panel) -->
        <toolWindow id="Coforge AI Agent"
                    secondary="false"
                    icon="AllIcons.Actions.Refresh"
                    anchor="right"
                    factoryClass="com.coforge.codingagent.ChatToolWindowFactory"/>

        <!-- Settings persistence -->
        <applicationService serviceImplementation="com.coforge.codingagent.AppSettingsState"/>

        <!-- Settings UI page -->
        <applicationConfigurable instance="com.coforge.codingagent.AppSettingsConfigurable"
                                 id="com.coforge.codingagent.AppSettingsConfigurable"
                                 displayName="Coforge AI Agent Settings"/>

        <!-- Build error capture (project-level) -->
        <projectService serviceImplementation="com.coforge.codingagent.BuildContextService"/>

        <!-- Dart Analysis Server LSP client (project-level, only active in Flutter projects) -->
        <projectService serviceImplementation="com.coforge.codingagent.DartLspService"/>

        <!-- URL content fetching and project type detection are stateless objects, no registration needed -->

        <!-- Inline ghost-text completions -->
        <codeInsight.inlineCompletion.provider
                implementation="com.coforge.codingagent.AiInlineCompletionProvider"/>

        <!-- Persistent chat history per project -->
        <projectService serviceImplementation="com.coforge.codingagent.ProjectHistoryService"/>

        <!-- Incremental index invalidation on file save -->
        <vfs.asyncListener implementation="com.coforge.codingagent.FileChangeListener"/>

    </extensions>

    <actions>
        <!-- Right-click context menu inside the editor -->
        <group id="CoforgeAiQuickActions"
               class="com.coforge.codingagent.QuickActionsGroup"
               text="Coforge AI"
               description="AI actions for selected code"
               popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </group>

        <!-- Standalone rename action — also accessible via Find Action (⌘⇧A) -->
        <action id="CoforgeAi.RenameSymbol"
                class="com.coforge.codingagent.RenameSymbolAction"
                text="Coforge AI: Rename Symbol Across Project…"
                description="Rename the symbol under cursor in all files">
            <keyboard-shortcut keymap="$default" first-keystroke="shift ctrl R"/>
        </action>
    </actions>

</idea-plugin>
